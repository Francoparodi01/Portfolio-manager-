# ── Broker ────────────────────────────────────────────────
COCOS_USERNAME=tu@email.com
COCOS_PASSWORD=tupassword

# ── Base de datos (TimescaleDB) ────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/portfolio

# ── Redis auxiliar ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=123456789

# ── Scraper ───────────────────────────────────────────────
HEADLESS=true
RETRY_ATTEMPTS=3
RETRY_BACKOFF_S=5
TIMEOUT_MS=60000
MIN_CONFIDENCE_SCORE=0.6
CACHE_TTL_SECONDS=300
DOM_HASH_TOLERANCE=0.85
SCREENSHOT_ON_FAILURE=true
SCREENSHOT_DIR=./screenshots
TELEGRAM_MFA_TIMEOUT=120

# ── URLs Cocos Capital ─────────────────────────────────────
COCOS_LOGIN_URL=https://app.cocos.capital/login
COCOS_PORTFOLIO_URL=https://app.cocos.capital/capital-portfolio
COCOS_MARKET_ACCIONES_URL=https://app.cocos.capital/market/acciones
COCOS_MARKET_CEDEARS_URL=https://app.cocos.capital/market/cedears

# ── Portfolio live / alertas ──────────────────────────────────────────────────
PORTFOLIO_REFRESH_SECONDS=300
PORTFOLIO_CACHE_TTL_SECONDS=600
PORTFOLIO_LIVE_POLL_SECONDS=60
PORTFOLIO_ALERT_MAJOR_PCT=0.03
PORTFOLIO_ALERT_WEIGHTED_PCT=0.02
PORTFOLIO_ALERT_MIN_WEIGHT=0.10
PORTFOLIO_ALERT_TTL_SECONDS=86400

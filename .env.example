# Cocos Copilot - ejemplo de entorno local.
# Copiar a .env y completar con credenciales propias. No commitear .env.

# Broker
COCOS_USERNAME=
COCOS_PASSWORD=
COCOS_TOTP_SECRET=

# Database / Docker local
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change_me_local_db_password
POSTGRES_DB=portfolio
DATABASE_URL=postgresql+asyncpg://portfolio:change_me_local_db_password@db:5432/portfolio
# Para correr scripts desde Windows contra el puerto publicado:
# DATABASE_URL=postgresql+asyncpg://portfolio:change_me_local_db_password@localhost:5432/portfolio

# Redis auxiliar
REDIS_URL=redis://localhost:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ADMIN_CHAT_IDS=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOW_ALL_CHATS=false
TELEGRAM_MFA_TIMEOUT=120

# Scraper
HEADLESS=true
RETRY_ATTEMPTS=3
RETRY_BACKOFF_S=5
TIMEOUT_MS=60000
MIN_CONFIDENCE_SCORE=0.6
CACHE_TTL_SECONDS=300
DOM_HASH_TOLERANCE=0.85
SCREENSHOT_ON_FAILURE=true
SCREENSHOT_DIR=./screenshots

# Monitor local
# Generar con:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
MONITOR_API_TOKEN=
MONITOR_API_PORT=8010
# Docker publica el monitor en 0.0.0.0:${MONITOR_API_PORT} para permitir localhost y Tailscale.
# La seguridad depende de token/TOTP/firewall/Tailscale ACL.
MONITOR_TOTP_SECRET=
MONITOR_AUTH_WINDOW_SECONDS=60
MONITOR_AUTH_MAX_FAILURES=8
MONITOR_TRUST_PROXY_HEADERS=false

# URLs Cocos Capital
COCOS_LOGIN_URL=https://app.cocos.capital/login
COCOS_PORTFOLIO_URL=https://app.cocos.capital/capital-portfolio
COCOS_MARKET_ACCIONES_URL=https://app.cocos.capital/market/acciones
COCOS_MARKET_CEDEARS_URL=https://app.cocos.capital/market/cedears

# Portfolio live / alertas
PORTFOLIO_REFRESH_SECONDS=300
PORTFOLIO_CACHE_TTL_SECONDS=600
PORTFOLIO_LIVE_POLL_SECONDS=60
PORTFOLIO_ALERT_MAJOR_PCT=0.06
PORTFOLIO_ALERT_WEIGHTED_PCT=0.04
PORTFOLIO_ALERT_MIN_WEIGHT=0.12
PORTFOLIO_ALERT_TTL_SECONDS=86400
INTRADAY_REVALIDATION_MAX_PER_MESSAGE=3
RISK_ALERT_TTL_SECONDS=21600
RISK_ALERT_MAX_PER_DIGEST=8

# Sentiment contextual (no modifica decisiones por default)
SENTIMENT_PIPELINE_ENABLED=true
SENTIMENT_PIPELINE_INTERVAL_SECONDS=900
SENTIMENT_PIPELINE_SCORE_LIMIT=20
SENTIMENT_OLLAMA_MODEL=qwen2.5:3b
SENTIMENT_HEURISTIC_FALLBACK=true
OLLAMA_URL=http://host.docker.internal:11434
# Yahoo ticker RSS: se agregan automáticamente los tickers de las carteras activas.
# Extras opcionales separados por coma; límite total para evitar fan-out excesivo.
SENTIMENT_YAHOO_TICKERS=
SENTIMENT_YAHOO_MAX_TICKERS=20
SENTIMENT_FETCH_CONCURRENCY=6
# CSV opcional para reemplazar feeds default:
# SENTIMENT_FEED_URLS=https://example.com/rss.xml,https://example.com/feed

# Pronosticos 5/20/40 ruedas en shadow; nunca genera planes ni ordenes.
THESIS_SHADOW_ENABLED=true

# Auditoria causal paralela del shadow; no modifica scores ni decisiones.
SHADOW_CAUSAL_OLLAMA_MODEL=qwen2.5:3b
SHADOW_CAUSAL_OLLAMA_TIMEOUT_SECONDS=90

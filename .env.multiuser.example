# Local-only multi-user sandbox. Copy to .env.multiuser.local before running.
# No usar tokens ni credenciales productivas en el sandbox.

POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change_me_local_db_password
POSTGRES_DB=portfolio
DATABASE_URL=postgresql+asyncpg://portfolio:change_me_local_db_password@db:5432/portfolio
REDIS_URL=redis://redis:6379/0

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=
MULTIUSER_ENABLED=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ADMIN_CHAT_IDS=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOW_ALL_CHATS=false

# One service account keeps scraping shared market data in the future.
COCOS_USERNAME=
COCOS_PASSWORD=
COCOS_TOTP_SECRET=

HEADLESS=true
RETRY_ATTEMPTS=3
RETRY_BACKOFF_S=5
TIMEOUT_MS=60000
TELEGRAM_MFA_TIMEOUT=120
PORTFOLIO_CACHE_TTL_SECONDS=600
